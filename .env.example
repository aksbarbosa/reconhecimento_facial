# Banco de dados (PostgreSQL local)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=face_access
DB_USER=seu_usuario
DB_PASSWORD=suasenha

# Chave de autenticação da API (gere com: python3 -c "import secrets; print(secrets.token_hex(32))")
API_KEY=cole_aqui_uma_chave_gerada

# Integração FaceNotify (Supabase)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=cole_aqui_a_anon_key_do_supabase
SUPABASE_SERVICE_ROLE_KEY=cole_aqui_a_service_role_key_do_supabase

# Supabase Edge Function
EDGE_FUNCTION_URL=https://seu-projeto.supabase.co/functions/v1/notify-recognition
WEBHOOK_SECRET=cole_aqui_o_mesmo_secret_configurado_no_supabase

# Identificação da câmera (usada no payload enviado ao FaceNotify)
CAMERA_ID=cam_001
CAMERA_LABEL=Câmera Principal - Entrada
CAMERA_ADDRESS=Rua das Flores, 123
CAMERA_CITY=São Paulo
CAMERA_STATE=SP
